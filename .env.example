# ============================================
# Web3 Builder Hub - 环境变量配置
# ============================================

# 数据库
POSTGRES_URL="postgresql://user:password@host:port/database"

# Brave Search API
BRAVE_SEARCH_API_KEY="your_brave_api_key"

# ============================================
# QQ Bot 配置（推荐）
# ============================================

# QQ 开放平台应用信息
QQ_APP_ID="your_qq_app_id"
QQ_APP_SECRET="your_qq_app_secret"

# 消息发送目标（三选一）
# - channel: 频道消息
# - group: 群消息  
# - c2c: 私聊消息
QQ_TARGET_TYPE="group"
QQ_TARGET_ID="your_target_id"

# 是否使用沙箱环境（开发时设为 true）
QQ_USE_SANDBOX="false"

# ============================================
# Telegram Bot 配置（可选，与 QQ Bot 二选一）
# ============================================
# TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
# TELEGRAM_CHAT_ID="your_chat_id"

# ============================================
# LLM 配置（统一 LLM 客户端）
# ============================================

# LLM 提供商: kimi | openai | groq | anthropic
LLM_PROVIDER=kimi

# 统一的 LLM API Key（根据提供商配置对应的 key）
# 或者使用 provider 特定的 key: KIMI_API_KEY, OPENAI_API_KEY, etc.
LLM_API_KEY="your_llm_api_key"

# 可选：指定模型（如果不设置，使用默认值）
# KIMI_MODEL=kimi-k2-turbo-preview
# OPENAI_MODEL=gpt-4o-mini
# GROQ_MODEL=llama-3.1-70b-versatile
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================
# Lark (飞书) 配置（可选）
# ============================================

# 飞书机器人 Webhook URL
LARK_WEBHOOK_URL="https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ============================================
# Cron 任务密钥（用于验证定时任务）
# ============================================
CRON_SECRET="your_cron_secret"

# ============================================
# Vercel 配置（自动设置）
# ============================================
# VERCEL_URL="your-vercel-app.vercel.app"
