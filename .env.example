# ============================================
# Web3 Builder Hub - 环境变量配置
# ============================================

# 数据库
POSTGRES_URL="postgresql://user:password@host:port/database"

# Brave Search API
BRAVE_SEARCH_API_KEY="your_brave_api_key"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_chat_id"

# Cron 任务密钥（用于验证定时任务）
CRON_SECRET="your_cron_secret"

# ============================================
# LLM 配置（统一 LLM 客户端）
# ============================================

# LLM 提供商: kimi | openai | groq | anthropic
LLM_PROVIDER=kimi

# 统一的 LLM API Key（根据提供商配置对应的 key）
LLM_API_KEY="your_llm_api_key"

# 可选：指定模型（如果不设置，使用默认值）
# KIMI_MODEL=kimi-k2-turbo-preview
# OPENAI_MODEL=gpt-4o-mini
# GROQ_MODEL=llama-3.1-70b-versatile
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================
# 旧版 Kimi 配置（向后兼容，建议迁移到上方统一配置）
# ============================================
# KIMI_API_KEY="your_kimi_api_key"

# ============================================
# Lark (飞书) 配置
# ============================================

# 飞书机器人 Webhook URL
LARK_WEBHOOK_URL="https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ============================================
# Vercel 配置（自动设置）
# ============================================
# VERCEL_URL="your-vercel-app.vercel.app"
